{
  "manifest_version": 3,
  "name": "FOR VIEECH",
  "version": "1.0.0",
  "description": "FOR VIEECH by mengxp — new tab dashboard: tabs grouped by domain, save for later, close with style.",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "FOR VIEECH · mengxp",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
