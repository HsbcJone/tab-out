{
  "manifest_version": 3,
  "name": "妈妈每天好心情",
  "version": "1.0.0",
  "description": "Zak 给妈妈的爱心新标签页：标签按网站归组、可稍后再看，整理得轻松一点。",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "妈妈每天好心情 · Zak",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
